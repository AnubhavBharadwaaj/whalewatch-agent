# --- WhaleWatch agent configuration ---
# Copy this file to .env and adjust. .env is gitignored; this template is not.

# Minimum USD value for a whale event to qualify. Architecture locks $10M.
WHALE_THRESHOLD_USD=10000000

# Poll interval in milliseconds. Production: 600000 (10 minutes).
# For testing, drop this to 5000 to watch the loop cycle quickly.
POLL_INTERVAL_MS=600000

# Spend controls — each completed cycle costs Ace Data credits (analyze + image
# + Luma video). Use these to bound credit burn.
#   MAX_CYCLES          total cycles before the agent stops gracefully. 0 = unlimited.
#                       Set to 1 for a single proof-of-pipeline run.
#   MAX_EVENTS_PER_POLL cycles started per poll. 0 = unlimited. Set to 1 to
#                       sample one whale per interval instead of a whole burst.
MAX_CYCLES=0
MAX_EVENTS_PER_POLL=0

# Event source: auto | mock | whale-alert | whale-alert-rest | eth-rpc
#   auto             — uses whale-alert (WebSocket) if WHALE_ALERT_API_KEY is set, else mock.
#   mock             — synthetic events, no network, no key.
#   whale-alert      — WebSocket push (Custom Alerts API). Requires paid ALERTS plan.
#   whale-alert-rest — REST polling (Transactions API). NOTE: Whale Alert's free
#                      plan authorises the key but returns no transaction data,
#                      so this needs a paid plan to be useful.
#   eth-rpc          — large USDC/USDT transfers via a public Ethereum RPC. Fully
#                      free, no API key, no billing. Recommended real-data source.
WHALE_SOURCE=auto

# Whale Alert API key (only used by whale-alert / whale-alert-rest).
WHALE_ALERT_API_KEY=

# Public Ethereum JSON-RPC endpoint for the eth-rpc source. The default needs no
# key. Alternatives: https://eth.llamarpc.com , https://eth.drpc.org
ETH_RPC_URL=https://ethereum-rpc.publicnode.com

# Where the idempotency store is persisted on disk.
IDEMPOTENCY_STORE_PATH=./data/idempotency.json

# --- Piece 2: x402 payments ---

# Operating mode: live | dry-run
#   live    -> x402 calls sign and settle real USDC on Solana mainnet
#   dry-run -> pipeline runs, but x402 calls settle nothing (testing / code review)
# Default is live. dry-run must be an explicit choice.
AGENT_MODE=dry-run

# Solana RPC for broadcasting x402 payments. In production use the Synapse
# mainnet endpoint: https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=YOUR_KEY
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Path to the agent's solana-keygen keypair JSON. Needed only in live mode.
# Generate with: solana-keygen new -o ./agent-keypair.json
AGENT_KEYPAIR_PATH=./agent-keypair.json

# --- Piece 2b: LLM analysis stage ---

# Ace Data Cloud API base URL.
ACE_DATA_BASE_URL=https://api.acedata.cloud

# Ace Data account API token (create one at platform.acedata.cloud). Sent as a
# Bearer header on x402 calls so the request routes to your account's model
# channels instead of the unprovisioned "default" group. Required for live calls.
ACE_API_TOKEN=

# LLM model for the analysis stage (cheap, capable). e.g. gpt-4o-mini, deepseek-v3
ACE_LLM_MODEL=gpt-4o-mini

# Image generation model. dall-e-3 via OpenAI image gen is the agent's primary
# path since OpenAI is provisioned in default group whereas Flux is not (the
# Flux "no available channel" issue is pending with the Ace Data dev team).
# Once Flux is unblocked, switch to flux-dev / flux-pro-1.1 etc.
ACE_IMAGE_MODEL=dall-e-3

# --- Piece 4: SAP registration ---

# Optional sell-side x402 endpoint to advertise on registration. Leave blank for none.
AGENT_X402_ENDPOINT=

# Optional metadata URI to advertise on registration (e.g. your GitHub repo). Blank for none.
AGENT_METADATA_URI=
