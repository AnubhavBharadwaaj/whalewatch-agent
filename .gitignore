# dependencies & build output
node_modules/
dist/

# runtime state (idempotency store, receipts)
data/

# secrets — never commit
.env
*.tmp

# Solana keypair files — NEVER commit these. A leaked keypair = drained wallet.
# When you generate one later with `solana-keygen new -o ./<name>.json`,
# make sure its exact filename is covered here.
oobe-agent.json
agent-keypair.json
*-keypair.json
id.json
